{
  "_comment": "Replace this file with your actual google-services.json from Firebase Console",
  "_instructions": [
    "1. Go to https://console.firebase.google.com",
    "2. Create a new project named 'StepSphere'",
    "3. Add an Android app with package name: com.stepsphere.app",
    "4. Download google-services.json and replace this file",
    "5. Also enable: Authentication (Email/Password), Firestore, Storage",
    "6. Run: flutterfire configure"
  ],
